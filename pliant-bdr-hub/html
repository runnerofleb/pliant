<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chris Khoury — How I'll Build Pliant's US Pipeline from Scratch</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600;700&family=Instrument+Serif:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg-primary: #0a0a0f;
  --bg-card: #111118;
  --bg-card-hover: #16161f;
  --bg-accent: #1a1a2e;
  --border: #1e1e2e;
  --border-accent: #2a2a3e;
  --text-primary: #e8e8f0;
  --text-secondary: #8888a8;
  --text-muted: #555570;
  --accent: #6366f1;
  --accent-dim: #4f46e5;
  --accent-glow: rgba(99, 102, 241, 0.15);
  --accent-green: #10b981;
  --accent-green-dim: rgba(16, 185, 129, 0.12);
  --accent-amber: #f59e0b;
  --accent-amber-dim: rgba(245, 158, 11, 0.12);
  --accent-red: #ef4444;
  --accent-cyan: #06b6d4;
  --accent-cyan-dim: rgba(6, 182, 212, 0.12);
  --font-mono: 'JetBrains Mono', monospace;
  --font-sans: 'Instrument Sans', -apple-system, sans-serif;
  --font-serif: 'Instrument Serif', Georgia, serif;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html {
  scroll-behavior: smooth;
  scroll-snap-type: y mandatory;
}

body {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: var(--font-sans);
  line-height: 1.6;
  overflow-x: hidden;
}

/* ─── NAV BAR ─── */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--text-secondary);
}
.nav-brand .dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12px var(--accent);
  animation: pulse-dot 2s ease infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.nav-slides {
  display: flex;
  gap: 2px;
}
.nav-slides button {
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  padding: 6px 12px;
  cursor: pointer;
  transition: all 0.2s;
}
.nav-slides button:first-child { border-radius: 6px 0 0 6px; }
.nav-slides button:last-child { border-radius: 0 6px 6px 0; }
.nav-slides button.active {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}
.nav-slides button:hover:not(.active) {
  background: var(--bg-card-hover);
  color: var(--text-primary);
}
.nav-keys {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.nav-keys kbd {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 2px 6px;
  font-size: 0.6rem;
}

/* ─── SLIDES ─── */
.slide {
  min-height: 100vh;
  scroll-snap-align: start;
  padding: 80px 2rem 3rem;
  display: flex;
  flex-direction: column;
  max-width: 1100px;
  margin: 0 auto;
}

/* ─── SECTION HEADERS ─── */
.section-tag {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: var(--accent);
  margin-bottom: 0.75rem;
  text-transform: uppercase;
}
.section-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  line-height: 1.15;
  margin-bottom: 0.5rem;
  color: var(--text-primary);
}
.section-subtitle {
  font-size: 1.05rem;
  color: var(--text-secondary);
  margin-bottom: 2.5rem;
  max-width: 600px;
}

/* ─── CARDS ─── */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.75rem;
  margin-bottom: 1rem;
  transition: border-color 0.3s;
}
.card:hover {
  border-color: var(--border-accent);
}
.card-label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1rem;
}
.card-title {
  font-size: 1.15rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}
.card-text {
  font-size: 0.92rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── GRID ─── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
.grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1rem; }

@media (max-width: 768px) {
  .grid-2, .grid-3, .grid-4 {
    grid-template-columns: 1fr;
  }
  .slide { padding: 80px 1.25rem 2rem; }
}

/* ─── STEP CARDS ─── */
.step {
  display: flex;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}
.step-num {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: var(--accent-glow);
  color: var(--accent);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(99, 102, 241, 0.2);
}
.step-content h4 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.35rem;
}
.step-content p {
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.65;
}

/* ─── SCRIPT BLOCK ─── */
.script-block {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.06), rgba(6, 182, 212, 0.04));
  border: 1px solid rgba(99, 102, 241, 0.15);
  border-radius: 12px;
  padding: 2rem;
  margin: 1.5rem 0;
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--text-primary);
  position: relative;
}
.script-block::before {
  content: '"';
  position: absolute;
  top: 0.5rem;
  left: 1rem;
  font-family: var(--font-serif);
  font-size: 4rem;
  color: var(--accent);
  opacity: 0.2;
  line-height: 1;
}
.script-block p {
  margin-bottom: 1rem;
  padding-left: 1rem;
}
.script-block p:last-child { margin-bottom: 0; }

/* ─── METRIC BARS ─── */
.metric-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--border);
}
.metric-row:last-child { border-bottom: none; }
.metric-label {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: var(--text-secondary);
}
.metric-label .icon {
  font-size: 1.1rem;
}
.metric-value {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--accent);
}

/* ─── CHECK LIST ─── */
.check-list {
  list-style: none;
}
.check-list li {
  padding: 0.5rem 0;
  font-size: 0.9rem;
  color: var(--text-secondary);
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
}
.check-list li::before {
  content: '✓';
  color: var(--accent-green);
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

/* ─── SEQUENCE TIMELINE ─── */
.timeline-item {
  display: flex;
  gap: 1rem;
  padding: 0.6rem 0;
  font-size: 0.85rem;
  color: var(--text-secondary);
  align-items: baseline;
}
.timeline-day {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--accent);
  min-width: 52px;
  flex-shrink: 0;
}

/* ─── EMAIL SAMPLE ─── */
.email-block {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 1rem;
}
.email-header {
  background: var(--bg-accent);
  padding: 0.85rem 1.25rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.email-header .tag {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-glow);
  padding: 3px 8px;
  border-radius: 4px;
}
.email-header .subject {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-primary);
}
.email-body {
  padding: 1.25rem;
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.7;
}
.email-body p { margin-bottom: 0.8rem; }
.email-body p:last-child { margin-bottom: 0; }

/* ─── RAMP PHASE ─── */
.ramp-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.ramp-header {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.ramp-header .phase {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 0.25rem;
}
.ramp-header h3 {
  font-size: 1.15rem;
  font-weight: 600;
}
.ramp-body {
  padding: 1.25rem 1.5rem;
}
.ramp-item {
  font-size: 0.85rem;
  color: var(--text-secondary);
  padding: 0.35rem 0;
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}
.ramp-item::before {
  content: '→';
  color: var(--text-muted);
  flex-shrink: 0;
}
.ramp-target {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--accent-green);
}

/* ─── CLOSE SECTION ─── */
.close-point {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 2rem;
}
.close-num {
  flex-shrink: 0;
  font-family: var(--font-mono);
  font-size: 2rem;
  font-weight: 700;
  color: var(--accent);
  opacity: 0.3;
  line-height: 1.2;
}
.close-content h4 {
  font-size: 1.05rem;
  font-weight: 600;
  margin-bottom: 0.4rem;
}
.close-content p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── HERO ─── */
.hero {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  flex: 1;
}
.hero-tag {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.hero-tag::before {
  content: '';
  width: 24px;
  height: 1px;
  background: var(--accent);
}
.hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 5.5vw, 4rem);
  font-weight: 400;
  line-height: 1.1;
  margin-bottom: 1.25rem;
  max-width: 800px;
}
.hero h1 em {
  font-style: italic;
  color: var(--accent);
}
.hero-sub {
  font-size: 1.15rem;
  color: var(--text-secondary);
  margin-bottom: 2.5rem;
  max-width: 550px;
  line-height: 1.6;
}
.hero-author {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.5rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
}
.hero-avatar {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--accent), var(--accent-cyan));
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1.1rem;
  color: white;
}
.hero-author-info .name {
  font-weight: 600;
  font-size: 1rem;
}
.hero-author-info .role {
  font-size: 0.82rem;
  color: var(--text-secondary);
}

/* ─── MATH BLOCK ─── */
.math-block {
  background: var(--accent-green-dim);
  border: 1px solid rgba(16, 185, 129, 0.2);
  border-radius: 12px;
  padding: 1.5rem 1.75rem;
  margin: 1rem 0;
}
.math-block .math-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-green);
  margin-bottom: 0.75rem;
}
.math-block p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 0.4rem;
}
.math-block .result {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 1rem;
  color: var(--accent-green);
  margin-top: 0.5rem;
}

/* ─── CLOSING BANNER ─── */
.closing-banner {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.08), rgba(6, 182, 212, 0.05));
  border: 1px solid rgba(99, 102, 241, 0.15);
  border-radius: 16px;
  padding: 3rem;
  text-align: center;
  margin-top: 2rem;
}
.closing-banner p {
  font-family: var(--font-serif);
  font-size: 1.35rem;
  font-style: italic;
  color: var(--text-primary);
  line-height: 1.6;
  max-width: 700px;
  margin: 0 auto;
}

/* ─── WHY SEGMENTS ─── */
.why-box {
  background: var(--accent-cyan-dim);
  border: 1px solid rgba(6, 182, 212, 0.15);
  border-radius: 12px;
  padding: 1.5rem 1.75rem;
  margin-top: 1rem;
}
.why-box .why-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  margin-bottom: 0.75rem;
}
.why-box p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── SEGMENT CARDS ─── */
.segment-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.segment-header {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.segment-badge {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 6px;
}
.segment-badge.direct {
  background: var(--accent-glow);
  color: var(--accent);
}
.segment-badge.partner {
  background: var(--accent-cyan-dim);
  color: var(--accent-cyan);
}
.segment-header h3 {
  font-size: 1.1rem;
  font-weight: 600;
}
.segment-body {
  padding: 1.25rem 1.5rem;
}
.segment-row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  padding: 0.4rem 0;
  font-size: 0.85rem;
}
.segment-row .label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--text-muted);
  min-width: 70px;
  flex-shrink: 0;
}
.segment-row .value {
  color: var(--text-secondary);
}

/* ─── HANDOFF NOTE ─── */
.handoff-note {
  background: var(--accent-amber-dim);
  border: 1px solid rgba(245, 158, 11, 0.15);
  border-radius: 12px;
  padding: 1.5rem 1.75rem;
  margin-top: 1rem;
}
.handoff-note .note-title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-amber);
  margin-bottom: 0.75rem;
}
.handoff-note p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ─── ACCOUNT PLAN ─── */
.account-plan {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.account-plan-header {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg-accent);
}
.account-plan-header h3 {
  font-size: 1rem;
  font-weight: 600;
}
.account-plan-header span {
  font-size: 0.82rem;
  color: var(--text-secondary);
}
.account-plan-body {
  padding: 1.25rem 1.5rem;
}
.plan-row {
  display: flex;
  gap: 0.75rem;
  padding: 0.45rem 0;
  font-size: 0.85rem;
  align-items: baseline;
}
.plan-row .key {
  font-weight: 600;
  color: var(--text-muted);
  min-width: 65px;
  flex-shrink: 0;
}
.plan-row .val {
  color: var(--text-secondary);
}

/* ─── WEEKLY RHYTHM ─── */
.rhythm-item {
  display: flex;
  gap: 1rem;
  padding: 0.6rem 0;
  font-size: 0.85rem;
  align-items: baseline;
}
.rhythm-day {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent-amber);
  min-width: 36px;
  flex-shrink: 0;
}
.rhythm-desc {
  color: var(--text-secondary);
}

/* ─── ANIMATIONS ─── */
.fade-in {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg-primary); }
::-webkit-scrollbar-thumb { background: var(--border-accent); border-radius: 3px; }
</style>
</head>
