<script>
const slides = document.querySelectorAll('.slide');
const totalSlides = slides.length;
let currentSlide = 0;
let visited = new Set([0]);

document.getElementById('slide-total').textContent = totalSlides;

// Build dots
const dotsEl = document.getElementById('dots');
for (let i = 0; i < totalSlides; i++) {
  const dot = document.createElement('div');
  dot.className = 'dot' + (i === 0 ? ' active' : '');
  dot.onclick = () => goToSlide(i);
  dotsEl.appendChild(dot);
}

function goToSlide(n) {
  if (n < 0 || n >= totalSlides || n === currentSlide) return;
  const direction = n > currentSlide ? 1 : -1;
  slides[currentSlide].className = 'slide ' + (direction > 0 ? 'exit-left' : '');
  currentSlide = n;
  visited.add(n);
  slides[currentSlide].className = 'slide active';

  // Update counter
  document.getElementById('slide-counter').textContent = n + 1;

  // Update dots
  document.querySelectorAll('.dot').forEach((d, i) => {
    d.className = 'dot' + (i === currentSlide ? ' active' : visited.has(i) ? ' visited' : '');
  });

  // Update buttons
  document.getElementById('prev-btn').disabled = currentSlide === 0;
  document.getElementById('next-btn').disabled = currentSlide === totalSlides - 1;
  document.getElementById('next-btn').textContent = currentSlide === totalSlides - 1 ? '✓ Done' : 'Next →';
}

function nextSlide() { goToSlide(currentSlide + 1); }
function prevSlide() { goToSlide(currentSlide - 1); }

// Keyboard nav
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); nextSlide(); }
  if (e.key === 'ArrowLeft') { e.preventDefault(); prevSlide(); }
});

// Touch/swipe
let touchStartX = 0;
document.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; });
document.addEventListener('touchend', (e) => {
  const diff = touchStartX - e.changedTouches[0].clientX;
  if (Math.abs(diff) > 60) { diff > 0 ? nextSlide() : prevSlide(); }
});
</script>
